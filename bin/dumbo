#!/usr/bin/php -d display_errors
<?php
/**
 * DumboPHP shell
 *
 * A PHP Framework for Rapid Development
 *
 * @package     DumboPHP
 * @author      Javier Serrano <rantes.javier@gmail.com>
 *
 */
if (file_exists('./config/host.php')) {
    require_once './config/host.php';
}
defined('INST_PATH') || define('INST_PATH', dirname(realpath(__DIR__).'../').'/');
set_include_path(
    '/etc/dumbophp'.PATH_SEPARATOR.
    '/etc/dumbophp/bin'.PATH_SEPARATOR.
    INST_PATH.PATH_SEPARATOR.
    INST_PATH.'bin'.PATH_SEPARATOR.
    INST_PATH.'lib'.PATH_SEPARATOR.
    get_include_path().PATH_SEPARATOR.
    PEAR_EXTENSION_DIR.PATH_SEPARATOR.
    '/windows/dumbophp'.PATH_SEPARATOR.
    '/windows/dumbophp/bin'.PATH_SEPARATOR.
    '/windows/system32/dumbophp'.PATH_SEPARATOR.
    '/windows/system32/dumbophp/bin'.PATH_SEPARATOR.
    INST_PATH
);

require_once 'dumbophp.php';

use DumboPHP\lib\Shell;
use function DumboPHP\unCamelize;
use DumboPHP\Config;
use DumboPHP\Connection;


spl_autoload_register(function ($class) {
    $path = explode('\\', $class);

    switch ($path[0]) {
        case 'DumboPHP':
            require_once implode('/', array_slice($path, 1)).'.php';
        break;
        case 'App':
            for ($i = 0; $i < sizeof($path); $i++):
                $path[$i] = unCamelize($path[$i]);
            endfor;
            $path = implode('/', $path);
            require_once INST_PATH."{$path}.php";
        break;
        case 'Migrations':
            $file = unCamelize($path[1]);
            require_once INST_PATH."migrations/{$file}.php";
        break;
        default:
            $path = implode('/', $path);
            require_once INST_PATH."{$path}.php";
    }

});

defined('APP_CONFIGS') || define('APP_CONFIGS', new Config());
defined('DB') || define('DB', new Connection());

$shell = new Shell();
$shell->run($argv);
